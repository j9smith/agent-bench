# ab.env - single config for the whole harness. Copy to ab.env and edit.
#   cp ab.env.example ab.env
# ab.env is gitignored (it holds your key). ab.env.example is the template.

# ---- model, as served by vLLM (no provider prefix) ----
MODEL=Qwen/Qwen3-32B-FP8

# ---- the API key vLLM is launched with, and that drivers must present ----
# Used BOTH as vLLM's --api-key (by `ab vllm-up`) and as the drivers' key.
# One value, one place. Change it here and everything agrees.
API_KEY=sk-CHANGE-ME

# ---- vLLM launch (used by `ab vllm-up`) ----
VLLM_PORT=8000
MAX_MODEL_LEN=40960            # Qwen3-32B's real ceiling is 40960; do not exceed
TOOL_CALL_PARSER=hermes        # Qwen3 uses the hermes parser
GPU_UTIL=0.90                  # LOWER THIS (e.g. 0.4) to force the KV pool to fill
                               # -> that's how you make eviction/preemption happen
EXTRA_VLLM_ARGS=               # anything else, e.g. "--quantization fp8"

# ---- proxy ----
PROXY_PORT=9000
INJECT_USAGE=1                 # capture token counts on streamed calls

# ---- prometheus (installed once onto the persistent volume) ----
PROM_PORT=9090
SCRAPE_INTERVAL=5              # seconds; must match `ab show --step`. 5s = finer
                               # per-request attribution than the old 15s default.
# Where to install prometheus so it survives pod restarts. Must be on the
# persistent volume (NOT /usr, which is ephemeral on RunPod).
PROM_DIR=/workspace/.prometheus

# ---- default run id (override per run: `ab run agentic -r myrun`) ----
RUN_ID=run1
